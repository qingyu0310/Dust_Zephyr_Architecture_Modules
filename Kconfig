# modules/Kconfig - hardware-facing modules built on top of drivers/topics

config MOD_DEV_POWERMETER
    bool "Horizon power meter"
    default n
    select COM_CAN
    help
        Horizon power meter module.

config MOD_DEV_MOTOR_DJI
    bool "DJI motor"
    default n
    select COM_CAN
    help
        DJI motor module.

config MOD_DEV_MOTOR_DM
    bool "DM motor"
    default n
    select COM_CAN
    help
        DM motor module.

config MOD_DEV_REMOTE
    bool "Remote receiver"
    default n
    select COM_UART_DMA
    select TPC_REMOTE_TO
    help
        Remote receiver module.

config MOD_DEV_IMU
    bool "IMU module"
    default n
    select FLT_QUATERNION_EKF
    select TPC_IMU_TO
    help
        IMU source decoupling, attitude EKF and zbus publish layer.

config MOD_DEV_IMU_BMI088
    bool "BMI088 IMU source"
    default n
    depends on MOD_DEV_IMU
    select COM_SPI
    help
        BMI088 source implementation for the IMU module.


